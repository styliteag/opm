# Pinned upstream nuclei image — multi-stage source for the statically
# linked nuclei binary. Keep this in sync with scanner/Dockerfile so the
# dev environment can run nuclei phases identically to prod.
ARG NUCLEI_VERSION=v3.7.1
FROM projectdiscovery/nuclei:${NUCLEI_VERSION} AS nuclei

FROM python:3.12-slim

WORKDIR /app

# Install masscan, networking tools, and tzdata for timezone support
RUN apt-get update && apt-get install -y --no-install-recommends \
    masscan \
    nmap \
    iputils-ping \
    tcpdump \
    iproute2 \
    net-tools \
    dnsutils \
    traceroute \
    netcat-openbsd \
    curl \
    wget \
    procps \
    psmisc \
    socat \
    tzdata \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Nuclei binary + community templates (mirrors scanner/Dockerfile). Templates
# are baked at build time; runtime updates are disabled inside the scanner
# via `-disable-update-check` so a running container never drifts.
# NOTE: do NOT pass `-duc` to `-update-templates` — it short-circuits the
# update and leaves the directory empty, which nuclei then rejects at scan
# time with "no templates provided for scan".
COPY --from=nuclei /usr/local/bin/nuclei /usr/local/bin/nuclei
ENV NUCLEI_TEMPLATES_DIR=/opt/nuclei-templates
RUN mkdir -p "${NUCLEI_TEMPLATES_DIR}" \
    && nuclei -update-templates -ud "${NUCLEI_TEMPLATES_DIR}" \
    && chmod -R a+rX "${NUCLEI_TEMPLATES_DIR}"

RUN mkdir -p /opt/opm/custom-scripts

ENV TZ=UTC

# Install uv for fast Python package management
# Install ssh-audit for SSH security probing
RUN pip install uv ssh-audit

# Copy project configuration
COPY pyproject.toml ./
COPY uv.lock* ./

# Install dependencies
RUN uv sync --frozen || uv sync

# Copy source (will be overridden by bind mount in dev)
COPY src ./src

# Run the scanner agent
CMD ["uv", "run", "python", "-m", "src.main"]
