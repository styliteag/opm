FROM node:22-slim

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy source (will be overridden by bind mount in dev)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Set Docker env for vite proxy config
ENV DOCKER=1

# Run Vite dev server
CMD ["npm", "run", "dev"]
