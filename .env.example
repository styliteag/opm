# Timezone Configuration
# Used for all containers (app, db, scanner) and cron schedule interpretation
TZ=Europe/Berlin
# Optional: Override schedule timezone separately (defaults to TZ if not set)
# SCHEDULE_TIMEZONE=Europe/Berlin

# Database Configuration
DB_ROOT_PASSWORD=rootpassword
DB_NAME=opm
DB_USER=opm
DB_PASSWORD=opmpassword

# Backend Configuration
DATABASE_URL=mysql+aiomysql://opm:opmpassword@db:3306/opm
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_EXPIRATION_MINUTES=60

# Initial Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# SMTP Configuration (for email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=true
ALERT_EMAIL_RECIPIENTS=
WEB_UI_URL=http://localhost:5173

# Scanner Configuration
SCANNER_BACKEND_URL=http://backend:8000
SCANNER_API_KEY=
SCANNER_POLL_INTERVAL=60
SCANNER_LOG_LEVEL=INFO

# Greenbone (GVM) Scanner Stack — only used with compose-gvm.yml
# Start with: docker compose -f compose-gvm.yml up -d

# Required: API key of the Scanner record created in OPM for the GVM scanner
GVM_SCANNER_API_KEY=

# URL the opm-scanner-gvm agent uses to reach the OPM backend
# - compose-dev.yml (cross-project): http://backend:8000 (default)
# - compose.yml (prod, combined app image): http://app:80
GVM_BACKEND_URL=http://backend:8000

# Scanner agent behavior
GVM_POLL_INTERVAL=60
GVM_LOG_LEVEL=INFO

# Credentials the scanner agent uses to authenticate against gvmd
# Change these after first startup (see README section on GVM setup):
#   docker compose -f compose-gvm.yml exec --user gvmd gvmd \
#     gvmd --user=admin --new-password=<new-password>
GVM_USER=admin
GVM_PASSWORD=admin

# GSA web UI HTTP port exposed by the nginx front-end
GVM_GSA_PORT=9392
